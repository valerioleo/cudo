{
  "name": "@cudo/etherscan",
  "version": "0.0.0",
  "type": "module",
  "description": "Verify contracts on Etherscan (V2, all chains) when cudo deploys them.",
  "license": "MIT",
  "author": "Valerio Leo",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "cudo": "*",
    "viem": ">=2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "cudo": "workspace:*",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valerioleo/cudo.git",
    "directory": "packages/cudo-etherscan"
  },
  "homepage": "https://github.com/valerioleo/cudo/tree/main/packages/cudo-etherscan#readme",
  "bugs": {
    "url": "https://github.com/valerioleo/cudo/issues"
  }
}
